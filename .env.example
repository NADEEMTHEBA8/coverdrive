COVERDRIVE_ENV=local
LOG_LEVEL=INFO

# Object storage — MinIO S3 API is mapped to host port 9100
COVERDRIVE_S3_ENDPOINT=http://localhost:9100
COVERDRIVE_S3_ENDPOINT_HOST=localhost:9100
COVERDRIVE_S3_ACCESS_KEY=minioadmin
COVERDRIVE_S3_SECRET_KEY=minioadmin
COVERDRIVE_S3_BUCKET=coverdrive
COVERDRIVE_S3_USE_SSL=false

# DuckDB warehouse written by dbt-build, read by the API
COVERDRIVE_WAREHOUSE_PATH=data/warehouse.duckdb

# API
API_HOST=0.0.0.0
API_PORT=8000

# Set to 1 to use fixture CSVs in tests/fixtures/ instead of live scrape
COVERDRIVE_USE_FIXTURES=1

# Slack webhook for Airflow failure alerts (optional — leave blank to disable)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
